# Staging environment — copy to staging server as .env
# NEVER use production credentials here.

APP_ENV=staging
NODE_ENV=production
PORT=3000
TZ=Asia/Dhaka

# Database (staging-only instance)
DATABASE_URL=mysql://staging_user:CHANGE_ME@staging-db-host:3306/paychek_staging
# Or discrete vars:
# DB_HOST=staging-db-host
# DB_PORT=3306
# DB_USER=staging_user
# DB_PASS=CHANGE_ME
# DB_NAME=paychek_staging

# Redis (staging)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_OP_TIMEOUT_MS=500

# Auth / monitoring
JWT_SECRET=CHANGE_ME_staging_jwt_secret
PAYMENT_METRICS_API_KEY=CHANGE_ME_staging_metrics_key
# PAYMENT_METRICS_IP_WHITELIST=10.0.0.0/8
# PAYMENT_METRICS_RATE_LIMIT=30

# bKash sandbox (optional global override; per-merchant config in website_official_gateways.config_json)
BKASH_API_BASE=https://tokenized.sandbox.bka.sh/v1.2.0-beta
# BKASH_PING_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized/checkout/token/grant

# Gate tests (local/staging CI only)
# GATE_TEST_WEBSITE_ID=7

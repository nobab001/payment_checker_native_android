# Payment Checker Backend

See `payment/STAGING_DEPLOY_GATE.md` for staging deployment.

PORT=3000
APP_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_db_password
DB_NAME=payment_checker_db
DATABASE_URL=mysql://root:your_db_password@127.0.0.1:3306/payment_checker_db
JWT_SECRET=generate_a_random_jwt_secret_here
PAYMENT_METRICS_API_KEY=generate_a_random_metrics_key_here
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
TRIAL_DEFAULT_DAYS=7

# Device Communication v2.5
PRESENCE_V25_DRY_RUN=1
# PRESENCE_V25_VERBOSE=1
# PRESENCE_V25_SHADOW=1


# JWT token expiry (optional, defaults: admin 12h, user 30d)
ADMIN_TOKEN_EXPIRES_IN=12h
USER_TOKEN_EXPIRES_IN=30d

# Admin slot passwords (required for admin console login, no fallback)
ADMIN_SLOT1_PASS=generate_a_random_slot1_pass_here
ADMIN_SLOT2_PASS=generate_a_random_slot2_pass_here
ADMIN_SLOT3_PASS=generate_a_random_slot3_pass_here

# Public HTTPS URL for gateway callbacks (Cloudflare Tunnel / paid ngrok / production).
# Do NOT use free ngrok G«ˆ browser interstitial breaks bKash return after PIN.
# Example: PUBLIC_BASE_URL=https://xxxx.trycloudflare.com
PUBLIC_BASE_URL=

# Optional bKash API host override (sandbox vs live)
# BKASH_API_BASE=https://tokenized.pay.bka.sh/v1.2.0-beta
# BKASH_API_BASE=https://tokenized.sandbox.bka.sh/v1.2.0-beta


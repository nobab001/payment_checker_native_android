generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model checkout_view_templates {
  id                          Int           @id @default(autoincrement())
  sms_template_id             Int           @unique(map: "uniq_sms_template")
  single_number_instruction   String        @db.Text
  multiple_number_instruction String        @db.Text
  created_at                  DateTime      @default(now()) @db.Timestamp(0)
  updated_at                  DateTime      @default(now()) @db.Timestamp(0)
  sms_templates               sms_templates @relation(fields: [sms_template_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_checkout_view_sms_template")
}

model device_trial_logs {
  id                   Int      @id @default(autoincrement())
  user_id              Int?
  android_id           String   @db.VarChar(255)
  hardware_fingerprint String   @db.VarChar(255)
  sim_slot_ids         String   @db.VarChar(255)
  has_used_trial       Int       @default(1) @db.TinyInt
  created_at           DateTime @default(now()) @db.Timestamp(0)

  @@unique([android_id, hardware_fingerprint, sim_slot_ids], map: "uniq_device_binding")
  @@index([android_id], map: "idx_android_id")
  @@index([android_id(length: 64)], map: "idx_dtl_android")
  @@index([hardware_fingerprint], map: "idx_fingerprint")
  @@index([sim_slot_ids], map: "idx_sim_slots")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model gateway_layouts {
  id            Int      @id @default(autoincrement())
  user_id       Int
  site_name     String   @default("") @db.VarChar(255)
  site_url      String?  @db.VarChar(512)
  api_key       String   @unique(map: "uniq_api_key") @default("") @db.VarChar(255)
  api_secret    String   @default("") @db.VarChar(255)
  layout_config String?  @db.LongText
  redirect_url  String?  @db.VarChar(512)
  callback_url  String?  @db.VarChar(512)
  is_active     Int       @default(1) @db.TinyInt
  created_at    DateTime @default(now()) @db.Timestamp(0)
  updated_at    DateTime @default(now()) @db.Timestamp(0)

  // ?? API Integration v2 (additive, backward-compatible) ?????????????
  merchant_id                 String?  @unique(map: "uniq_merchant_id") @db.VarChar(64)
  company_name                String?  @db.VarChar(255)
  logo_url                    String?  @db.VarChar(512)
  checkout_theme              String?  @default("default") @db.VarChar(50)
  success_url                 String?  @db.VarChar(512)
  cancel_url                  String?  @db.VarChar(512)
  webhook_url                 String?  @db.VarChar(512)
  checkout_mode               String?  @default("transaction") @db.VarChar(30) // transaction | merchant_vibe
  api_secret_hash             String?  @db.VarChar(128)
  api_secret_last4            String?  @db.VarChar(8)
  api_secret_version          Int      @default(1)
  number_order_json           String?  @db.LongText // checkout-only ordering + enable/disable overrides
  receive_payment_type        Int      @default(0) @db.TinyInt // merchant preference
  receive_commission          Int      @default(0) @db.TinyInt // merchant preference
  allow_payment_type_callback Int      @default(0) @db.TinyInt // admin permission
  allow_commission_callback   Int      @default(0) @db.TinyInt // admin permission
  commission_enabled          Int      @default(0) @db.TinyInt // admin unlock for commission menu
  website_purpose             String   @default("add_balance") @db.VarChar(32) // add_balance | payment | both
  purpose_selected            Int      @default(0) @db.TinyInt // merchant explicitly chose purpose
  purpose_locked              Int      @default(0) @db.TinyInt // lock-once; super-admin unlock only
  purpose_locked_at           DateTime? @db.DateTime(0)

  users               users                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_gateway_user")
  merchant_commissions merchant_commissions[]
  checkout_vibe_requests checkout_vibe_requests[]
  payment_sessions       payment_sessions[]
  website_official_gateways website_official_gateways[]
  merchant_accounts      merchant_accounts[]

  @@index([user_id, is_active], map: "idx_gateway_active")
  @@index([user_id], map: "idx_gateway_user")
}

model merchant_commissions {
  id              Int      @id @default(autoincrement())
  website_id      Int
  payment_type    String   @db.VarChar(50) // bkash_personal, nagad_merchant, card, bank, etc.
  commission_type String   @default("percentage") @db.VarChar(20) // percentage | flat
  commission_value Decimal @default(0.00) @db.Decimal(12, 2)
  charge_type     String   @default("flat") @db.VarChar(20) // percentage | flat
  charge_value    Decimal  @default(0.00) @db.Decimal(12, 2)
  is_active       Int      @default(1) @db.TinyInt
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @db.Timestamp(0)
  gateway_layouts gateway_layouts @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_commission_website")

  @@unique([website_id, payment_type], map: "uniq_website_payment_type")
  @@index([website_id], map: "idx_commission_website")
}

model checkout_vibe_requests {
  id             Int      @id @default(autoincrement())
  website_id     Int
  payment_session_token String? @db.VarChar(80)
  customer_number String  @db.VarChar(20)
  amount         Decimal  @db.Decimal(12, 2)
  status         String   @default("waiting") @db.VarChar(20) // waiting | matched | expired | cancelled
  matched_trx_id String?  @db.VarChar(191)
  matched_history_id Int?
  expires_at     DateTime @db.DateTime(0)
  matched_at     DateTime? @db.DateTime(0)
  created_at     DateTime @default(now()) @db.Timestamp(0)
  gateway_layouts gateway_layouts @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_vibe_website")

  @@index([website_id, status], map: "idx_vibe_website_status")
  @@index([customer_number, amount, status], map: "idx_vibe_match")
  @@index([expires_at], map: "idx_vibe_expiry")
}

// ?? API Integration v2: Payment Flow routing (Phase 6) ?????????????????????
// A payment session is created when a merchant server initiates a payment. It
// records the intended amount server-side (tamper-proof) and routes the customer
// either to the PayCheck checkout (transaction/vibe) or to an official gateway.
model payment_sessions {
  id               Int      @id @default(autoincrement())
  session_token    String   @unique(map: "uniq_session_token") @db.VarChar(80)
  website_id       Int
  user_id          Int
  order_id         String?  @db.VarChar(191) // merchant's own order reference
  amount           Decimal  @db.Decimal(12, 2)
  currency         String   @default("BDT") @db.VarChar(8)
  channel          String   @default("paycheck") @db.VarChar(20) // paycheck | official
  official_provider String? @db.VarChar(40) // bkash_merchant | nagad_merchant | rocket_merchant | sslcommerz | card | bank
  customer_number  String?  @db.VarChar(20)
  status           String   @default("created") @db.VarChar(20) // created | redirected | completed | failed | expired
  trx_id           String?  @db.VarChar(191)
  matched_history_id Int?
  success_url      String?  @db.VarChar(512)
  cancel_url       String?  @db.VarChar(512)
  callback_url     String?  @db.VarChar(512)
  webhook_url      String?  @db.VarChar(512)
  meta_json        String?  @db.LongText
  expires_at       DateTime @db.DateTime(0)
  completed_at     DateTime? @db.DateTime(0)
  created_at       DateTime @default(now()) @db.Timestamp(0)
  gateway_layouts  gateway_layouts @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_session_website")

  @@index([website_id, status], map: "idx_session_website_status")
  @@index([status, expires_at], map: "idx_session_expiry")
  @@index([order_id], map: "idx_session_order")
  @@unique([website_id, trx_id], map: "uniq_website_trx")
}

/// Merchant callback outbox ? durable delivery after payment SUCCESS (Phase-3B.5).
model merchant_callback_outbox {
  id            Int       @id @default(autoincrement())
  delivery_key  String    @unique(map: "uniq_mcb_delivery_key") @db.VarChar(191)
  session_token String    @db.VarChar(80)
  website_id    Int
  target_url    String    @db.VarChar(512)
  payload_json  String    @db.LongText
  trace_id      String?   @db.VarChar(64)
  status        String    @default("pending") @db.VarChar(20) // pending | processing | sent | dead
  attempts      Int       @default(0)
  last_error    String?   @db.VarChar(512)
  locked_at     DateTime? @db.DateTime(0)
  locked_by     String?   @db.VarChar(64)
  sent_at       DateTime? @db.DateTime(0)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  @@index([status, created_at], map: "idx_mcb_status_created")
  @@index([session_token], map: "idx_mcb_session")
}

// Per-website configuration for official (non-PayCheck) payment channels.
// redirect_url_template supports placeholders: {amount} {order_id} {token}
// {callback_url} {currency} {customer_number}.
model website_official_gateways {
  id                    Int      @id @default(autoincrement())
  website_id            Int
  provider              String   @db.VarChar(40) // bkash_merchant | nagad_merchant | rocket_merchant | sslcommerz | card | bank
  display_name          String?  @db.VarChar(100)
  redirect_url_template String   @db.VarChar(1024)
  is_active             Int      @default(1) @db.TinyInt
  config_json           String?  @db.LongText // extra credentials/config (store minimal; secrets ideally in vault)
  created_at            DateTime @default(now()) @db.Timestamp(0)
  updated_at            DateTime @default(now()) @db.Timestamp(0)
  gateway_layouts       gateway_layouts @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_official_website")

  @@unique([website_id, provider], map: "uniq_website_official_provider")
  @@index([website_id, is_active], map: "idx_official_website_active")
}

// Live merchant accounts ? multiple accounts per provider per website.
// Sensitive credentials (api_secret, password, app_secret) are AES-encrypted
// (iv:ciphertext hex) via utils/merchantCrypto.js. Never returned in plaintext.
model merchant_accounts {
  id              Int      @id @default(autoincrement())
  website_id      Int
  provider        String   @db.VarChar(40) // bkash | nagad | rocket | upay | ...
  merchant_name   String   @db.VarChar(120)
  merchant_ref    String?  @db.VarChar(120) // optional merchant id/ref shown on card
  logo_url        String?  @db.VarChar(512)
  api_key         String?  @db.VarChar(512)
  api_secret_enc  String?  @db.Text
  username        String?  @db.VarChar(255)
  password_enc    String?  @db.Text
  app_key         String?  @db.VarChar(512)
  app_secret_enc  String?  @db.Text
  base_url        String?  @db.VarChar(512)
  callback_url    String?  @db.VarChar(512)
  is_active       Int      @default(1) @db.TinyInt
  is_default      Int      @default(0) @db.TinyInt
  priority        Int      @default(0)
  notes           String?  @db.Text
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamp(0)
  gateway_layouts gateway_layouts @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_merchant_account_website")

  @@index([website_id, is_active], map: "idx_merchant_acct_website_active")
  @@index([website_id, provider, is_active], map: "idx_merchant_acct_provider")
}

// Lightweight append-only audit trail (Phase 8). Write-mostly; never blocks the
// request path (all writes are fire-and-forget).
model audit_logs {
  id          Int      @id @default(autoincrement())
  event_type  String   @db.VarChar(60)
  entity_type String?  @db.VarChar(40)
  entity_id   String?  @db.VarChar(80)
  website_id  Int?
  user_id     Int?
  ip          String?  @db.VarChar(64)
  status      String?  @db.VarChar(20)
  detail_json String?  @db.LongText
  created_at  DateTime @default(now()) @db.Timestamp(0)

  @@index([event_type, created_at], map: "idx_audit_event")
  @@index([website_id], map: "idx_audit_website")
}

model gateway_methods {
  id              Int      @id @default(autoincrement())
  user_id         String   @db.VarChar(255)
  device_id       String   @default("") @db.VarChar(255)
  sim_slot        Int      @default(1)
  provider        String   @db.VarChar(50)
  number          String   @db.VarChar(20)
  display_name    String?  @db.VarChar(100)
  is_enabled      Int      @default(0) @db.TinyInt
  priority        Int      @default(0)
  template_id     Int?
  custom_patterns String?  @db.Text
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @db.Timestamp(0)

  @@index([template_id], map: "idx_template")
  @@index([user_id], map: "idx_user")
  @@index([user_id, device_id], map: "idx_user_device")
}

model sim_slot_bindings {
  id                Int      @id @default(autoincrement())
  user_id           String   @db.VarChar(255)
  device_id         String   @default("") @db.VarChar(255)
  sim_slot          Int      @default(1) @db.TinyInt
  phone_number      String   @default("") @db.VarChar(20)
  is_active         Int      @default(0) @db.TinyInt
  merchant_enabled  Int      @default(1) @db.TinyInt
  created_at        DateTime @default(now()) @db.Timestamp(0)
  updated_at        DateTime @default(now()) @db.Timestamp(0)

  @@unique([user_id, device_id, sim_slot], map: "uniq_user_device_slot")
  @@index([user_id, phone_number, is_active], map: "idx_user_number_active")
}

model comm_policy {
  id                      Int      @id @default(autoincrement())
  package_key             String   @unique(map: "uniq_comm_policy_package") @db.VarChar(32)

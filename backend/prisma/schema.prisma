}

model global_config {
  config_key   String   @id @db.VarChar(128)
  config_value String   @db.Text
  updated_at   DateTime @default(now()) @db.Timestamp(0)
}

model otp_sms_templates {
  id            Int      @id @default(autoincrement())
  setting_key   String   @unique(map: "uniq_setting_key") @db.VarChar(128)
  setting_value String?  @db.Text

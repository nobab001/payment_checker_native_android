model user_credentials {
  id          Int                   @id @default(autoincrement())
  user_id     Int
  type        user_credentials_type
  value       String                @unique(map: "uniq_cred_value") @db.VarChar(255)
  verified_at DateTime?             @db.DateTime(0)
  created_at  DateTime              @default(now()) @db.Timestamp(0)
  users       users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_cred_user")

  @@index([user_id, type], map: "idx_cred_user_type")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id                 Int                  @id @default(autoincrement())
  name               String               @default("") @db.VarChar(255)
  avatar             String?              @db.VarChar(255)
  phone              String?              @unique(map: "uniq_phone") @db.VarChar(20)
  email              String?              @unique(map: "uniq_email") @db.VarChar(255)
  pin                String               @default("") @db.VarChar(255)
  balance            Decimal              @default(0.00) @db.Decimal(12, 2)
  blocked            Int       @default(0) @db.TinyInt
  role               String               @default("user") @db.VarChar(20)
  is_paid            Int?      @default(0) @db.TinyInt
  active_plan_name   String?              @default("FREE_LEVEL") @db.VarChar(50)
  expiry_date        DateTime?            @db.Date
  profile_complete   Int       @default(0) @db.TinyInt
  sms_enabled             Int                  @default(1) @db.TinyInt
  gmail_enabled           Int                  @default(0) @db.TinyInt
  has_custom_sender_addon Int                  @default(0) @db.TinyInt
  custom_sender_ends_at   DateTime?            @db.Date
  active_addon_plan_id    Int?
  perm_custom_sender      Int                  @default(0) @db.TinyInt
  perm_template           Int                  @default(0) @db.TinyInt
  perm_website            Int                  @default(0) @db.TinyInt
  perm_device             Int                  @default(0) @db.TinyInt
  eff_max_devices         Int                  @default(1)
  eff_max_sites           Int                  @default(1)
  fcm_token               String?              @db.VarChar(512)
  secretKey          String?              @db.VarChar(128)
  secretKeyVersion   Int                  @default(1) @db.UnsignedInt
  secretKeyCreatedAt DateTime?            @db.Timestamp(0)
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  updated_at         DateTime             @default(now()) @db.Timestamp(0)
  gateway_layouts    gateway_layouts[]
  registered_devices registered_devices[]
  sms_history        sms_history[]
  sms_parse_failures sms_parse_failures[]
  sms_templates      sms_templates[]
  user_credentials   user_credentials[]

  @@index([blocked], map: "idx_blocked")
  @@index([role], map: "idx_role")
}

enum user_credentials_type {
  phone
  email
}

enum registered_devices_status {
  pending
  active
  rejected
}

model custom_sms_archives {
  id           Int      @id @default(autoincrement())
  user_id      Int
  device_id    String   @db.VarChar(255)
  sim_slot     Int?     @db.TinyInt
  sim_number   String?  @db.VarChar(32)
  provider_tag String   @db.VarChar(128)
  sender_id    String?  @db.VarChar(128)
  full_sms     String   @db.Text
  created_at   DateTime @default(now()) @db.Timestamp(0)

  @@index([user_id])
  @@index([user_id, created_at])
}


/// Official website sandbox visitors ? isolated from real users/merchants. Auto-purge after TTL.
model demo_visitors {
  id              Int             @id @default(autoincrement())
  public_id       String          @unique(map: "uniq_demo_public_id") @db.VarChar(40)
  display_name    String          @db.VarChar(64)
  token_hash      String          @db.VarChar(64)
  host_website_id Int?
  settings_json   String?         @db.LongText
  ip_hash         String?         @db.VarChar(64)
  user_agent_hash String?         @db.VarChar(64)
  status          String          @default("active") @db.VarChar(16)
  expires_at      DateTime        @db.Timestamp(0)
  last_seen_at    DateTime        @db.Timestamp(0)
  created_at      DateTime        @default(now()) @db.Timestamp(0)
  payments        demo_payments[]

  @@index([status, expires_at], map: "idx_demo_visitors_expiry")
  @@index([ip_hash, created_at], map: "idx_demo_visitors_ip")
}

model demo_payments {
  id            Int           @id @default(autoincrement())
  visitor_id    Int
  amount        Decimal       @db.Decimal(12, 2)
  purpose       String        @default("pay") @db.VarChar(32)
  order_id      String?       @db.VarChar(128)
  session_token String?       @db.VarChar(128)
  status        String        @default("initiated") @db.VarChar(32)
  created_at    DateTime      @default(now()) @db.Timestamp(0)
  visitor       demo_visitors @relation(fields: [visitor_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_demo_payment_visitor")

  @@index([visitor_id, created_at], map: "idx_demo_payments_visitor")
}

  password      String    @db.VarChar(255)
  host          String    @default("smtp.gmail.com") @db.VarChar(255)
  port          Int       @default(465)
  secure        Int       @default(1) @db.TinyInt
  daily_limit   Int       @default(500)
  sent_today    Int       @default(0)
  last_reset_at DateTime? @db.Timestamp(0)
  is_active     Int       @default(1) @db.TinyInt
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @db.Timestamp(0)
}

model subscription_plans {
  id                       Int      @id @default(autoincrement())
  plan_name                String   @unique(map: "plan_name") @db.VarChar(50)
  price                    Decimal  @db.Decimal(10, 2)
  max_sites                Int
  max_devices              Int
  is_custom_sender_allowed Int      @default(0) @db.TinyInt
  duration_days            Int?     @default(365)
  plan_category            String   @default("personal") @db.VarChar(32)
  perm_template            Int      @default(1) @db.TinyInt
  perm_website             Int      @default(1) @db.TinyInt
  perm_device              Int      @default(1) @db.TinyInt
  perm_smart_popup         Int      @default(0) @db.TinyInt
  features_json            String?  @db.Text
  sort_order               Int      @default(0)
  created_at               DateTime @default(now()) @db.Timestamp(0)
}

model addon_plans {
  id                Int      @id @default(autoincrement())
  plan_name         String   @unique(map: "uniq_addon_plan_name") @db.VarChar(100)
  price             Decimal  @default(0.00) @db.Decimal(10, 2)
  duration_days     Int      @default(30)
  description       String?  @db.Text
  is_active         Int      @default(1) @db.TinyInt
  max_devices       Int      @default(2)
  perm_custom_sender Int     @default(1) @db.TinyInt
  perm_template     Int      @default(0) @db.TinyInt
  perm_website      Int      @default(0) @db.TinyInt
  perm_device       Int      @default(1) @db.TinyInt
  perm_smart_popup  Int      @default(0) @db.TinyInt
  features_json     String?  @db.Text
  sort_order        Int      @default(0)
  created_at        DateTime @default(now()) @db.Timestamp(0)

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ================================================================
         Paychek — online.paychek.app
         Permissions required by blueprint (Section 4)
         ================================================================ -->

    <!-- Internet & Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- SMS — Core feature: reading incoming payment SMS -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Phone state & number detection for SIMs -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />

    <!-- Foreground Service — keeps SMS listener alive -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Wake Lock — prevents CPU sleep during SMS processing -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Boot — restart service after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery optimization — request user to exempt app from Doze -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Post Notifications (Android 13+) — foreground service notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact Alarm — WorkManager reliable scheduling on Android 12+ -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:name=".PaychekApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PaymentChecker">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustNothing">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SMS BroadcastReceiver — receives incoming SMS intents -->
        <receiver
            android:name=".services.sms.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Boot BroadcastReceiver — ফোন রিস্টার্টের পর SMS সার্ভিস পুনরায় চালু করে -->
        <receiver
            android:name=".services.boot.BootReceiver"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- SMS Foreground Service
             foregroundServiceType:
               dataSync    — backend sync (offline queue upload)
               specialUse  — Android 14+ mandatory for services that read SMS ContentProvider
        -->
        <service
            android:name=".services.foreground.SmsMonitorService"
            android:foregroundServiceType="dataSync|specialUse"
            android:exported="false">
            <property 
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" 
                android:value="আমাদের পেমেন্ট চেকার অ্যাপের অফলাইন মার্চেন্টদের জন্য ব্যাকগ্রাউন্ডে SMS ContentProvider ইনবক্স স্ক্যানিং সিঙ্ক নিশ্চিত করতে specialUse টাইপটি আবশ্যক।" />
        </service>

        <!-- Accessibility Service to assist with background tracking -->
        <service
            android:name=".services.accessibility.PaychekAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>

